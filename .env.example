# DriveMate Mobile — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Backend API
EXPO_PUBLIC_API_URL=https://your-backend.com/api/v1
EXPO_PUBLIC_SOCKET_URL=https://your-backend.com

# Google Maps (get from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# MSG91 OTP Widget (get from msg91.com)
EXPO_PUBLIC_MSG91_WIDGET_ID=your_widget_id
EXPO_PUBLIC_MSG91_TOKEN_AUTH=your_token_auth

# Cloudinary (get from cloudinary.com)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Admin phone numbers (comma-separated)
EXPO_PUBLIC_ADMIN_PHONES=your_admin_phone

# Cashfree Payments (get from cashfree.com)
EXPO_PUBLIC_CASHFREE_APP_ID=your_cashfree_app_id
EXPO_PUBLIC_CASHFREE_ENV=PRODUCTION
CASHFREE_PAYOUT_CLIENT_ID=your_payout_client_id
